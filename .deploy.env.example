# Deploy config
# Copy this file to .deploy.env and configure

# Server IP
SERVER_IP=your-server-ip

# Server user
SERVER_USER=root

# Server password (only needed for SSH key setup)
SERVER_PASS=your-password

# Remote directory for frontend files
REMOTE_DIR=/var/www/html

# Local build directory (relative to project root)
LOCAL_DIST=frontend/dist

# Nginx container name (auto reload after deploy)
NGINX_CONTAINER=hata-nginx
